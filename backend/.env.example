# Database connection (async PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/startuptracker

# OpenAI API for LLM extraction
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# CORS origins (comma-separated, frontend URL)
CORS_ORIGINS=http://localhost:3000

# RSS feed URLs for cron ingestion (comma-separated)
FEED_URLS=
